{
  "name": "lp-mine-skains",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b --pretty false",
    "format": "prettier --write \"**/*.{ts,mjs,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,mjs,yml,yaml}\""
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@types/node": "24.0.15",
    "eslint": "9.31.0",
    "prettier": "3.6.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0",
    "vitest": "3.2.4"
  }
}
