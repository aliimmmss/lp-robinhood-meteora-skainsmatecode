---
import '../styles/global.css'
import data from '../data.json'

type FeePool = {
  feeTier: number
  poolAddress: string
  pair: string | null
  status: 'complete' | 'partial' | 'insufficient'
  windowSeconds: number | null
  sampleCount: number
  currentTick: number | null
  dailyFeesCombinedInToken1Decimal: string | null
  occupancy: { bands: { label: string; occupancyDecimal: string }[] } | null
}

type HealthPool = {
  feeTier: number
  status: 'healthy' | 'degraded' | 'critical'
  lastObservedAt: string | null
  ageSeconds: number | null
  observationCount: number
  coveragePercent: string | null
  riskFlags: string[]
}

type Alert = { severity: 'warning' | 'critical'; code: string; feeTier: number; message: string }

const generatedAt = data.generatedAt
const health = data.health as {
  status: 'healthy' | 'degraded' | 'critical'
  summary: { poolCounts: { total: number; healthy: number; degraded: number; critical: number } }
  pools: HealthPool[]
  alerts: Alert[]
}
const fees = data.fees as { configuredWindowSeconds: number; referenceLiquidity: string; pools: FeePool[] }

type DepositPlan = {
  poolAddress: string
  feeTier: number
  rangePercent: number
  tickLower: number
  tickUpper: number
  currentPriceToken1PerToken0: string
  priceLowerToken1PerToken0: string
  priceUpperToken1PerToken0: string
  pair: string
}
const depositPlan = (data.depositPlan ?? null) as DepositPlan | null
const uniswapCreateUrl = 'https://app.uniswap.org/positions/create'

type Opportunity = {
  name: string
  address: string
  feeTierPercent: number
  ageHours: number
  marketCapUsd: number | null
  reserveUsd: number
  volume24hUsd: number
  volumeToTvl: number
  estDailyFeeReturnPercent: string
  volumeTrend: 'rising' | 'steady' | 'fading'
  passesScreen: boolean
  screenNotes: string[]
}
const opportunitiesReport =
  data.opportunities && 'opportunities' in data.opportunities
    ? (data.opportunities as { opportunities: Opportunity[] })
    : null
const opportunities = opportunitiesReport ? opportunitiesReport.opportunities.slice(0, 15) : []

const feePercent = (tier: number) => `${tier / 10_000}%`
const hasFeeData = fees.pools.some((pool) => pool.status !== 'insufficient')

function formatUsdCompact(value: number | null): string {
  if (value === null || !Number.isFinite(value)) return '—'
  if (value >= 1_000_000) return `$${(value / 1_000_000).toFixed(1)}M`
  if (value >= 1_000) return `$${(value / 1_000).toFixed(0)}K`
  return `$${value.toFixed(0)}`
}

const trendColor = {
  rising: 'text-emerald-400',
  steady: 'text-neutral-400',
  fading: 'text-amber-400',
} as const

function truncateAddress(address: string): string {
  return address.length > 12 ? `${address.slice(0, 6)}…${address.slice(-4)}` : address
}
const geckoPoolUrl = (address: string) => `https://www.geckoterminal.com/robinhood/pools/${address}`

function formatUsdgPerDay(decimal: string | null): string {
  if (decimal === null) return '—'
  const usdg = Number(decimal) / 1_000_000 // USDG has 6 decimals
  if (!Number.isFinite(usdg)) return '—'
  return usdg.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

function formatOccupancy(pool: FeePool): string {
  const band = pool.occupancy?.bands.find((entry) => entry.label === '±1%')
  if (!band) return '—'
  return `${(Number(band.occupancyDecimal) * 100).toFixed(0)}%`
}

function formatAge(seconds: number | null): string {
  if (seconds === null) return '—'
  if (seconds < 60) return `${seconds}s`
  const minutes = Math.floor(seconds / 60)
  if (minutes < 60) return `${minutes}m`
  const hours = Math.floor(minutes / 60)
  if (hours < 24) return `${hours}h ${minutes % 60}m`
  return `${Math.floor(hours / 24)}d ${hours % 24}h`
}

function formatTimestamp(iso: string): string {
  return new Date(iso).toISOString().slice(0, 19).replace('T', ' ') + ' UTC'
}
function formatJakarta(iso: string): string {
  return (
    new Date(iso)
      .toLocaleString('en-CA', {
        timeZone: 'Asia/Jakarta',
        hour12: false,
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
      })
      .replace(',', '') + ' WIB'
  )
}

const statusText = {
  healthy: 'text-emerald-400',
  degraded: 'text-amber-400',
  critical: 'text-red-400',
} as const
const statusDot = {
  healthy: 'bg-emerald-500',
  degraded: 'bg-amber-500',
  critical: 'bg-red-500',
} as const

const favicon =
  'data:image/svg+xml,' +
  encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><rect width="16" height="16" fill="%23000"/><rect x="3" y="3" width="10" height="10" fill="none" stroke="%23d4d4d4"/></svg>')
---

<!doctype html>
<html lang="en" class="bg-black">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>LP Mine — WETH/USDG monitoring</title>
    <meta
      name="description"
      content="Read-only monitoring for WETH/USDG Uniswap v3 liquidity pools on Robinhood Chain: pool health, coverage, and fee yield by tier."
    />
    <meta name="robots" content="noindex" />
    <link rel="icon" href={favicon} />
  </head>
  <body class="min-h-dvh bg-black text-neutral-300 antialiased">
    <main class="mx-auto max-w-3xl px-5 py-12">
      <header class="mb-10">
        <h1 class="text-balance text-xl font-semibold text-neutral-100">LP Mine</h1>
        <p class="text-pretty text-sm text-neutral-500">
          WETH/USDG liquidity monitoring — Robinhood Chain
        </p>
        <p class="mt-3 font-mono text-xs tabular-nums text-neutral-600">
          Snapshot {formatTimestamp(generatedAt)} · {formatJakarta(generatedAt)}
        </p>
      </header>

      <section class="mb-10 flex items-center gap-2.5" aria-label="Overall health">
        <span class={`inline-block size-2 rounded-full ${statusDot[health.status]}`}></span>
        <span class={`text-sm font-medium ${statusText[health.status]}`}>
          {health.status.toUpperCase()}
        </span>
        <span class="text-sm text-neutral-500">
          · {health.summary.poolCounts.healthy}/{health.summary.poolCounts.total} pools healthy
        </span>
      </section>

      <section class="mb-10">
        <h2 class="mb-1 text-sm font-medium text-neutral-100">Fee yield by tier</h2>
        <p class="mb-4 text-pretty text-xs text-neutral-500">
          Combined daily fees per {fees.referenceLiquidity} liquidity units, in USDG, ranked highest
          first. Estimated from past fee-growth over ~{Math.round(fees.configuredWindowSeconds / 3600)}h;
          realized only while a position stays in range.
        </p>

        {
          hasFeeData ? (
            <div class="overflow-x-auto rounded-lg border border-neutral-800">
              <table class="w-full text-sm">
                <thead>
                  <tr class="text-left text-xs uppercase tracking-wide text-neutral-500">
                    <th class="px-3 py-2 font-medium">Tier</th>
                    <th class="px-3 py-2 text-right font-medium">USDG / day</th>
                    <th class="px-3 py-2 text-right font-medium">±1% in-range</th>
                    <th class="px-3 py-2 text-right font-medium">Status</th>
                  </tr>
                </thead>
                <tbody>
                  {fees.pools.map((pool) => (
                    <tr class="border-t border-neutral-900">
                      <td class="px-3 py-2 tabular-nums text-neutral-200">{feePercent(pool.feeTier)}</td>
                      <td class="px-3 py-2 text-right font-mono tabular-nums text-neutral-100">
                        {formatUsdgPerDay(pool.dailyFeesCombinedInToken1Decimal)}
                      </td>
                      <td class="px-3 py-2 text-right font-mono tabular-nums text-neutral-400">
                        {formatOccupancy(pool)}
                      </td>
                      <td class="px-3 py-2 text-right text-xs text-neutral-500">{pool.status}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="rounded-lg border border-neutral-800 p-6">
              <p class="text-pretty text-sm text-neutral-400">
                Not enough data yet. The hourly monitor is still collecting observations.
              </p>
              <p class="mt-1 text-pretty text-xs text-neutral-500">
                Fee yield needs at least two fee-growth samples per pool. Check back after the monitor
                has run for a day.
              </p>
            </div>
          )
        }
      </section>

      <section class="mb-10">
        <h2 class="mb-1 text-sm font-medium text-neutral-100">Deposit plan</h2>
        {
          depositPlan ? (
            <div class="rounded-lg border border-neutral-800 p-4">
              <p class="mb-3 text-pretty text-xs text-neutral-500">
                Computed for the top-ranked pinned pool at ±{depositPlan.rangePercent}% around the current
                price. Prepares the exact numbers only — you review and sign in your own wallet. Confirm
                the pool address against the registry evidence, and wait for HEALTHY data before acting.
              </p>
              <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm sm:grid-cols-3">
                <div>
                  <dt class="text-xs text-neutral-500">Pair · tier</dt>
                  <dd class="tabular-nums text-neutral-200">
                    {depositPlan.pair} · {depositPlan.feeTier / 10_000}%
                  </dd>
                </div>
                <div>
                  <dt class="text-xs text-neutral-500">Price range (USDG per WETH)</dt>
                  <dd class="font-mono tabular-nums text-neutral-100">
                    {depositPlan.priceLowerToken1PerToken0} – {depositPlan.priceUpperToken1PerToken0}
                  </dd>
                </div>
                <div>
                  <dt class="text-xs text-neutral-500">Current price</dt>
                  <dd class="font-mono tabular-nums text-neutral-400">
                    {depositPlan.currentPriceToken1PerToken0}
                  </dd>
                </div>
                <div>
                  <dt class="text-xs text-neutral-500">Tick range</dt>
                  <dd class="font-mono tabular-nums text-neutral-400">
                    {depositPlan.tickLower} / {depositPlan.tickUpper}
                  </dd>
                </div>
                <div class="col-span-2 sm:col-span-3">
                  <dt class="text-xs text-neutral-500">Pool address (verify)</dt>
                  <dd class="break-all font-mono text-xs text-neutral-400">{depositPlan.poolAddress}</dd>
                </div>
              </dl>
              <ol class="mt-4 list-decimal space-y-1 pl-5 text-xs text-neutral-400">
                <li>Open the Uniswap create page on Robinhood Chain (chain 4663).</li>
                <li>Select the {depositPlan.pair} pair at the {depositPlan.feeTier / 10_000}% fee tier.</li>
                <li>Set the price range to the bounds above.</li>
                <li>Enter your deposit amount — start tiny.</li>
                <li>Review the approval and mint, then sign in your wallet.</li>
              </ol>
              <a
                href={uniswapCreateUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-block rounded border border-neutral-700 px-3 py-1 text-xs text-neutral-200 hover:border-neutral-500"
              >
                Open Uniswap create page
              </a>
            </div>
          ) : (
            <div class="rounded-lg border border-neutral-800 p-6">
              <p class="text-pretty text-sm text-neutral-400">No deposit-ready pool yet.</p>
              <p class="mt-1 text-pretty text-xs text-neutral-500">
                A plan appears once a pinned pool has complete fee data. Let the monitor accumulate a day
                of observations first.
              </p>
            </div>
          )
        }
      </section>

      <section id="watchlist-section" class="mb-10 hidden">
        <h2 class="mb-1 text-sm font-medium text-neutral-100">Watchlist</h2>
        <p class="mb-4 text-pretty text-xs text-neutral-500">
          Pools you promoted, saved in this browser. Live metrics from GeckoTerminal.
        </p>
        <div class="overflow-x-auto rounded-lg border border-neutral-800">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-xs uppercase tracking-wide text-neutral-500">
                <th class="px-3 py-2 font-medium">Pool</th>
                <th class="px-3 py-2 text-right font-medium">Est / day</th>
                <th class="px-3 py-2 text-right font-medium">Vol/TVL</th>
                <th class="px-3 py-2 text-right font-medium">24h vol</th>
                <th class="px-3 py-2 text-right font-medium">TVL</th>
                <th class="px-3 py-2 text-right font-medium">Trend</th>
                <th class="px-3 py-2 text-right font-medium">&nbsp;</th>
              </tr>
            </thead>
            <tbody id="watchlist-body"></tbody>
          </table>
        </div>
      </section>

      <section class="mb-10">
        <div class="mb-1 flex items-baseline justify-between gap-2">
          <h2 class="text-sm font-medium text-neutral-100">Opportunities</h2>
          <span id="opps-live" class="font-mono text-xs tabular-nums text-neutral-600">build snapshot</span>
        </div>
        <p class="mb-4 text-pretty text-xs text-neutral-500">
          All Robinhood pools ranked by estimated daily fee return (volume ÷ TVL × fee tier).
          Screen follows the MeteoraIDN criteria: market cap ≥ $250K, 24h volume ≥ $1M, age ≥ 24h,
          volume/TVL ≥ 0.5. Third-party data (GeckoTerminal), unverified on-chain — research signal
          only, not a recommendation.
        </p>

        {
          opportunities.length > 0 ? (
            <div class="overflow-x-auto rounded-lg border border-neutral-800">
              <table class="w-full text-sm">
                <thead>
                  <tr class="text-left text-xs uppercase tracking-wide text-neutral-500">
                    <th class="px-3 py-2 font-medium">Pool</th>
                    <th class="px-3 py-2 text-right font-medium">Est / day</th>
                    <th class="px-3 py-2 text-right font-medium">Vol/TVL</th>
                    <th class="px-3 py-2 text-right font-medium">24h vol</th>
                    <th class="px-3 py-2 text-right font-medium">TVL</th>
                    <th class="px-3 py-2 text-right font-medium">Trend</th>
                    <th class="px-3 py-2 text-right font-medium">Screen</th>
                    <th class="px-3 py-2 text-right font-medium">&nbsp;</th>
                  </tr>
                </thead>
                <tbody id="opps-body">
                  {opportunities.map((entry) => (
                    <tr class="border-t border-neutral-900">
                      <td class="px-3 py-2">
                        <div class="max-w-[11rem] truncate text-neutral-200">{entry.name}</div>
                        <a
                          href={geckoPoolUrl(entry.address)}
                          target="_blank"
                          rel="noopener noreferrer"
                          title={entry.address}
                          class="font-mono text-xs text-neutral-500 hover:text-neutral-300"
                        >
                          {truncateAddress(entry.address)}
                        </a>
                      </td>
                      <td class="px-3 py-2 text-right font-mono tabular-nums text-neutral-100">
                        {entry.estDailyFeeReturnPercent}%
                      </td>
                      <td class="px-3 py-2 text-right font-mono tabular-nums text-neutral-400">
                        {entry.volumeToTvl.toFixed(1)}
                      </td>
                      <td class="px-3 py-2 text-right font-mono tabular-nums text-neutral-400">
                        {formatUsdCompact(entry.volume24hUsd)}
                      </td>
                      <td class="px-3 py-2 text-right font-mono tabular-nums text-neutral-400">
                        {formatUsdCompact(entry.reserveUsd)}
                      </td>
                      <td class={`px-3 py-2 text-right text-xs ${trendColor[entry.volumeTrend]}`}>
                        {entry.volumeTrend}
                      </td>
                      <td class="px-3 py-2 text-right text-xs">
                        {entry.passesScreen ? (
                          <span class="text-emerald-400">pass</span>
                        ) : (
                          <span class="text-neutral-500">review</span>
                        )}
                      </td>
                      <td class="px-3 py-2 text-right">
                        <button
                          type="button"
                          data-watch={entry.address}
                          class="rounded border border-neutral-700 px-2 py-0.5 text-xs text-neutral-400 hover:text-neutral-100"
                        >
                          watch
                        </button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="rounded-lg border border-neutral-800 p-6">
              <p class="text-pretty text-sm text-neutral-400">Opportunity feed unavailable.</p>
              <p class="mt-1 text-pretty text-xs text-neutral-500">
                The third-party source did not return data on the last build. It refreshes on the next
                deploy.
              </p>
            </div>
          )
        }
      </section>

      <section class="mb-10">
        <h2 class="mb-4 text-sm font-medium text-neutral-100">Pool health</h2>
        <div class="overflow-x-auto rounded-lg border border-neutral-800">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-xs uppercase tracking-wide text-neutral-500">
                <th class="px-3 py-2 font-medium">Tier</th>
                <th class="px-3 py-2 text-right font-medium">Last obs</th>
                <th class="px-3 py-2 text-right font-medium">Coverage</th>
                <th class="px-3 py-2 text-right font-medium">Obs</th>
                <th class="px-3 py-2 text-right font-medium">Flags</th>
              </tr>
            </thead>
            <tbody>
              {health.pools.map((pool) => (
                <tr class="border-t border-neutral-900">
                  <td class="px-3 py-2 tabular-nums text-neutral-200">{feePercent(pool.feeTier)}</td>
                  <td class="px-3 py-2 text-right font-mono tabular-nums text-neutral-400">
                    {formatAge(pool.ageSeconds)}
                  </td>
                  <td class="px-3 py-2 text-right font-mono tabular-nums text-neutral-400">
                    {pool.coveragePercent ?? '—'}
                  </td>
                  <td class="px-3 py-2 text-right font-mono tabular-nums text-neutral-400">
                    {pool.observationCount}
                  </td>
                  <td class="px-3 py-2 text-right text-xs text-neutral-500">
                    {pool.riskFlags.length > 0 ? pool.riskFlags.join(', ') : '—'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="mb-10">
        <h2 class="mb-4 text-sm font-medium text-neutral-100">Active alerts</h2>
        {
          health.alerts.length > 0 ? (
            <ul class="space-y-2">
              {health.alerts.map((alert) => (
                <li class="rounded-lg border border-neutral-800 px-3 py-2 text-sm">
                  <span class={alert.severity === 'critical' ? statusText.critical : statusText.degraded}>
                    {alert.severity}
                  </span>
                  <span class="text-neutral-500"> · {feePercent(alert.feeTier)} · {alert.code}</span>
                  <p class="text-pretty text-neutral-400">{alert.message}</p>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-neutral-500">No active alerts.</p>
          )
        }
      </section>

      <footer class="border-t border-neutral-900 pt-6">
        <p class="text-pretty text-xs text-neutral-600">
          Read-only monitoring. Figures are estimates of past fees per unit of liquidity, realized only
          while a position stays in range — not a guaranteed APR, and not a recommendation to deploy
          capital. No wallet is connected and nothing here can move funds.
        </p>
      </footer>
    </main>
    <script>
      import { fetchAndRankOpportunities, type Opportunity } from '../lib/opportunity'

      const WATCHLIST_KEY = 'lp-mine-watchlist'
      const NUM = 'px-3 py-2 text-right font-mono tabular-nums'
      const trendClass: Record<string, string> = {
        rising: 'text-emerald-400',
        steady: 'text-neutral-400',
        fading: 'text-amber-400',
      }

      function getWatchlist(): string[] {
        try {
          const value: unknown = JSON.parse(localStorage.getItem(WATCHLIST_KEY) ?? '[]')
          return Array.isArray(value) ? (value as string[]) : []
        } catch {
          return []
        }
      }
      function setWatchlist(list: string[]): void {
        localStorage.setItem(WATCHLIST_KEY, JSON.stringify(list))
      }
      function esc(value: string): string {
        const el = document.createElement('div')
        el.textContent = value
        return el.innerHTML
      }
      function usd(value: number | null): string {
        if (value === null || !Number.isFinite(value)) return '—'
        if (value >= 1e6) return '$' + (value / 1e6).toFixed(1) + 'M'
        if (value >= 1e3) return '$' + (value / 1e3).toFixed(0) + 'K'
        return '$' + value.toFixed(0)
      }
      function truncAddr(address: string): string {
        return address.length > 12 ? `${address.slice(0, 6)}…${address.slice(-4)}` : address
      }
      function cells(o: Opportunity): string {
        const addr =
          `<a href="https://www.geckoterminal.com/robinhood/pools/${esc(o.address)}" target="_blank" rel="noopener noreferrer"` +
          ` title="${esc(o.address)}" class="font-mono text-xs text-neutral-500 hover:text-neutral-300">${truncAddr(o.address)}</a>`
        return (
          `<td class="px-3 py-2"><div class="max-w-[11rem] truncate text-neutral-200">${esc(o.name)}</div>${addr}</td>` +
          `<td class="${NUM} text-neutral-100">${o.estDailyFeeReturnPercent}%</td>` +
          `<td class="${NUM} text-neutral-400">${o.volumeToTvl.toFixed(1)}</td>` +
          `<td class="${NUM} text-neutral-400">${usd(o.volume24hUsd)}</td>` +
          `<td class="${NUM} text-neutral-400">${usd(o.reserveUsd)}</td>` +
          `<td class="px-3 py-2 text-right text-xs ${trendClass[o.volumeTrend]}">${o.volumeTrend}</td>`
        )
      }
      function watchButton(address: string, active: boolean, label: string): string {
        const cls = active
          ? 'border-emerald-700 text-emerald-400'
          : 'border-neutral-700 text-neutral-400 hover:text-neutral-100'
        return `<button type="button" data-watch="${esc(address)}" class="rounded border px-2 py-0.5 text-xs ${cls}">${label}</button>`
      }

      let current: Opportunity[] = []

      function render(): void {
        const watched = getWatchlist()
        const body = document.getElementById('opps-body')
        if (body) {
          body.innerHTML = current
            .slice(0, 15)
            .map((o) => {
              const on = watched.includes(o.address)
              const screen = o.passesScreen
                ? '<span class="text-emerald-400">pass</span>'
                : '<span class="text-neutral-500">review</span>'
              return `<tr class="border-t border-neutral-900">${cells(o)}<td class="px-3 py-2 text-right text-xs">${screen}</td><td class="px-3 py-2 text-right">${watchButton(o.address, on, on ? 'watching' : 'watch')}</td></tr>`
            })
            .join('')
        }
        const section = document.getElementById('watchlist-section')
        const wbody = document.getElementById('watchlist-body')
        if (section && wbody) {
          if (watched.length > 0) {
            section.classList.remove('hidden')
            const rows = current.filter((o) => watched.includes(o.address))
            wbody.innerHTML =
              rows.length > 0
                ? rows
                    .map(
                      (o) =>
                        `<tr class="border-t border-neutral-900">${cells(o)}<td class="px-3 py-2 text-right">${watchButton(o.address, true, 'remove')}</td></tr>`,
                    )
                    .join('')
                : '<tr><td colspan="7" class="px-3 py-3 text-sm text-neutral-500">Watched pools are not in the current top results.</td></tr>'
          } else {
            section.classList.add('hidden')
          }
        }
      }

      document.addEventListener('click', (event) => {
        const el = event.target
        if (!(el instanceof HTMLElement)) return
        const target = el.closest('[data-watch]')
        const address = target?.getAttribute('data-watch')
        if (!address) return
        const list = getWatchlist()
        const index = list.indexOf(address)
        if (index >= 0) list.splice(index, 1)
        else list.push(address)
        setWatchlist(list)
        render()
      })

      // Auto-refresh cadence. GeckoTerminal's free API allows ~30 calls/min and
      // each refresh is 3 page-calls, so 15s (12 calls/min) stays safely under.
      // The volume figures are 1h/6h/24h aggregates — they do not change faster.
      const REFRESH_MS = 15_000
      let refreshing = false

      async function refresh(): Promise<void> {
        if (refreshing || document.hidden) return
        refreshing = true
        const live = document.getElementById('opps-live')
        try {
          current = await fetchAndRankOpportunities(3)
          if (live) {
            const now = new Date()
            const utc = now.toISOString().slice(11, 19)
            const wib = now.toLocaleTimeString('en-GB', { timeZone: 'Asia/Jakarta', hour12: false })
            live.textContent = 'live · ' + utc + ' UTC · ' + wib + ' WIB'
          }
          render()
        } catch {
          if (live) live.textContent = 'live fetch failed — retrying'
        } finally {
          refreshing = false
        }
      }

      void refresh()
      setInterval(() => void refresh(), REFRESH_MS)
      // Refresh immediately when the tab becomes visible again.
      document.addEventListener('visibilitychange', () => {
        if (!document.hidden) void refresh()
      })
    </script>
  </body>
</html>
